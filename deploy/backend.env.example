WENYAO_ENV=production
WENYAO_DATABASE_URL=sqlite:////app/data/wenyao.db
WENYAO_GUA_DATA_DIR=/app/public/gua
WENYAO_ALLOWED_ORIGINS=https://gua.lovinghlx.cn
WENYAO_COOKIE_SECURE=true
WENYAO_TIMEZONE=Asia/Shanghai
WENYAO_DETAIL_READING_DAILY_LIMIT=3

WENYAO_AI_BASE_URL=https://your-model-host/v1
WENYAO_AI_API_KEY=your-api-key
WENYAO_AI_MODEL=your-model-name
WENYAO_AI_TEMPERATURE=0.7
WENYAO_AI_TIMEOUT_SECONDS=60
