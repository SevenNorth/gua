# map
server {
		server_name  map.lovinghlx.cn;
		root         /webapps/map;

		location / {  
				try_files $uri $uri/ /index.html;
		}

		location ~/dtzx/[^\.]*$ {
				alias   /webapps/dtzx/;
				try_files $uri $uri/ index.html break;
		}
		location /dtzx/ {
				alias   /webapps/dtzx/;
				index  index.html;
		}

    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/picsur.lovinghlx.cn/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/picsur.lovinghlx.cn/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot



}
# tiff
server {
		server_name  tiff.lovinghlx.cn;
		root         /webapps/preview_tiff;

		location / {  
				try_files $uri $uri/ /index.html;
		}

		location ~* \.(tif|tiff|png|gif|webp|jpg|jpeg)$ {
				add_header Access-Control-Allow-Origin *;   
				add_header Access-Control-Allow-Methods 'GET, OPTIONS';
